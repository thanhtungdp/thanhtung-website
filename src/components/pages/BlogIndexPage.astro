---
import { Image } from 'astro:assets';
import BaseHead from '../BaseHead.astro';
import Footer from '../Footer.astro';
import FormattedDate from '../FormattedDate.astro';
import Header from '../Header.astro';
import { SITE_TITLE } from '../../consts';
import { getTranslations, type Locale } from '../../i18n';
import { getBlogPath, getBlogPosts } from '../../lib/blog';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const posts = await getBlogPosts(locale);
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={`${t.blog.title} | ${SITE_TITLE}`} description={t.blog.description} locale={locale} />
	</head>
	<body>
		<Header />
		<main class="blog-index-shell">
			<section class="blog-hero">
				<p>{posts.length} {locale === 'vi' ? 'bài viết' : 'articles'}</p>
				<h1>{t.blog.title}</h1>
				<span>{t.blog.description}</span>
			</section>

			<section class="posts-list" aria-label={t.blog.title}>
				{
					posts.map((post, index) => (
						<article class:list={['post-row surface-card', { featured: index === 0 }]}>
							<a href={getBlogPath(post, locale)}>
								{post.data.heroImage && (
									<div class="post-media">
										<Image width={640} height={360} src={post.data.heroImage} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
									</div>
								)}
								<div class="post-content">
									<p class="date"><FormattedDate date={post.data.pubDate} locale={locale} /></p>
									<h2>{post.data.title}</h2>
									<p class="description">{post.data.description}</p>
									<span>{t.blog.readMore}</span>
								</div>
							</a>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-index-shell {
		padding-top: 4rem;
	}

	.blog-hero {
		max-width: 840px;
		margin-bottom: 2.25rem;
	}

	.blog-hero p {
		display: inline-flex;
		margin-bottom: 0.9rem;
		padding: 0.42rem 0.7rem;
		border: 1px solid rgb(var(--border));
		border-radius: 999px;
		background: rgb(255 255 255 / 0.72);
		color: rgb(var(--primary));
		font-size: 0.82rem;
		font-weight: 800;
	}

	.blog-hero span {
		display: block;
		max-width: 58ch;
		color: rgb(var(--muted-foreground));
		font-size: clamp(1.05rem, 2vw, 1.22rem);
	}

	.posts-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.post-row {
		overflow: hidden;
		transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
	}

	.post-row:hover {
		transform: translateY(-3px);
		border-color: rgb(var(--primary) / 0.3);
	}

	.post-row a {
		display: flex;
		flex-direction: column;
		height: 100%;
		color: inherit;
		text-decoration: none;
	}

	.post-row.featured {
		grid-column: auto;
	}

	.post-media {
		aspect-ratio: 4 / 3;
		background: linear-gradient(135deg, rgb(255 247 237 / 0.9), rgb(255 255 255 / 0.95));
		overflow: hidden;
	}

	.post-row img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		border-radius: 0;
	}

	.post-content {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: clamp(1rem, 2vw, 1.35rem);
	}

	.date {
		margin-bottom: 0.7rem;
		color: rgb(var(--primary));
		font-size: 0.82rem;
		font-weight: 800;
	}

	.post-content h2 {
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		font-size: clamp(1.12rem, 2vw, 1.5rem);
		line-height: 1.12;
		letter-spacing: -0.04em;
	}

	.post-row:not(.featured) .post-content h2 {
		font-size: clamp(1.12rem, 2vw, 1.5rem);
	}

	.description {
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		color: rgb(var(--muted-foreground));
		font-size: 0.98rem;
		line-height: 1.58;
	}

	.post-content span {
		margin-top: auto;
		padding-top: 1rem;
		color: rgb(var(--primary));
		font-size: 0.92rem;
		font-weight: 800;
	}

	@media (max-width: 1100px) {
		.posts-list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 760px) {
		.blog-index-shell {
			padding-top: 2.5rem;
		}

		.posts-list {
			grid-template-columns: 1fr;
		}
	}
</style>
