---
import { getAlternateLinks, getLocaleFromUrl, getTranslations, localizePath } from '../i18n';
import DavidTungLogo from '../assets/david-tung-logo-upload.png';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const locale = getLocaleFromUrl(Astro.url);
const t = getTranslations(locale);
const alternateLinks = getAlternateLinks(Astro.url.pathname);
---

<header class="site-header">
	<nav class="site-nav" aria-label="Main navigation">
		<a class="brand" href={localizePath('/', locale)} aria-label={`${SITE_TITLE} home`}>
			<img class="brand-logo" src={DavidTungLogo.src} alt="" width="900" height="219" decoding="async" />
		</a>

		<div class="nav-links">
			<HeaderLink href={localizePath('/', locale)}>{t.nav.home}</HeaderLink>
			<HeaderLink href={localizePath('/blog', locale)}>{t.nav.blog}</HeaderLink>
			<HeaderLink href={localizePath('/about', locale)}>{t.nav.about}</HeaderLink>
		</div>

		<div class="language-links" aria-label="Language selector">
			{
				alternateLinks.map((link) => (
					<a href={link.path} class:list={{ active: link.locale === locale }} hreflang={link.locale}>
						{link.locale.toUpperCase()}
					</a>
				))
			}
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		padding: 0.75rem 1rem;
		background: rgb(var(--background) / 0.78);
		backdrop-filter: blur(18px) saturate(160%);
		border-bottom: 1px solid rgb(var(--border) / 0.72);
	}

	.site-nav {
		width: min(var(--container), 100%);
		min-height: 3.8rem;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		text-decoration: none;
	}

	.brand-logo {
		display: block;
		width: clamp(9.6rem, 16vw, 14.75rem);
		height: auto;
		border-radius: 0 !important;
		clip-path: none !important;
		mask-image: none !important;
	}

	.nav-links {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.25rem;
		padding: 0.28rem;
		border: 1px solid rgb(var(--border) / 0.84);
		border-radius: 999px;
		background: rgb(255 255 255 / 0.7);
		box-shadow: 0 1px 2px rgb(15 23 42 / 0.04);
	}

	.nav-links :global(a) {
		padding: 0.55rem 0.9rem;
		border-radius: 999px;
		color: rgb(var(--muted-foreground));
		font-size: 0.94rem;
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
	}

	.nav-links :global(a:hover) {
		color: rgb(var(--foreground));
		background: rgb(var(--muted));
	}

	.nav-links :global(a.active) {
		color: rgb(var(--foreground));
		background: white;
		box-shadow: 0 8px 22px rgb(15 23 42 / 0.08);
	}

	.language-links {
		display: inline-flex;
		justify-self: end;
		gap: 0.35rem;
		align-items: center;
		padding: 0.25rem;
		border: 1px solid rgb(var(--border) / 0.84);
		border-radius: 999px;
		background: rgb(255 255 255 / 0.72);
	}

	.language-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.45rem;
		padding: 0.5rem 0.65rem;
		border-radius: 999px;
		color: rgb(var(--muted-foreground));
		font-size: 0.76rem;
		font-weight: 800;
		line-height: 1;
		text-decoration: none;
	}

	.language-links a:hover {
		color: rgb(var(--foreground));
		background: rgb(var(--muted));
	}

	.language-links a.active {
		background: rgb(var(--primary));
		color: rgb(var(--primary-foreground));
	}

	@media (max-width: 760px) {
		.site-header {
			padding: 0.55rem 0.5rem;
		}

		.site-nav {
			grid-template-columns: 1fr auto;
			gap: 0.6rem;
			min-height: auto;
		}

		.brand-logo {
			width: min(11rem, 48vw);
		}

		.nav-links {
			grid-column: 1 / -1;
			width: 100%;
			justify-content: space-between;
			order: 3;
		}

		.nav-links :global(a) {
			flex: 1;
			text-align: center;
			padding-inline: 0.45rem;
		}

		.language-links {
			justify-self: end;
		}
	}
</style>
