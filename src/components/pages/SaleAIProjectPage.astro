---
import { Image } from 'astro:assets';
import BaseHead from '../BaseHead.astro';
import Footer from '../Footer.astro';
import Header from '../Header.astro';
import { SITE_TITLE } from '../../consts';
import { localizePath, type Locale } from '../../i18n';
import QuoteFeature from '../../assets/projects/sale-ai/quote-60s-feature.webp';
import EventFeature from '../../assets/projects/sale-ai/event-demo-feature.webp';
import AgentConceptSlide from '../../assets/projects/sale-ai/slide-03.webp';
import CaseSlide from '../../assets/projects/sale-ai/slide-04.webp';
import EnterpriseImpactSlide from '../../assets/projects/sale-ai/slide-06.webp';
import PainSlide from '../../assets/projects/sale-ai/slide-08.webp';
import StrategySlide from '../../assets/projects/sale-ai/slide-09.webp';
import QuoteSlide from '../../assets/projects/sale-ai/slide-10.webp';
import FlowSlide from '../../assets/projects/sale-ai/slide-14.webp';
import StopwatchSlide from '../../assets/projects/sale-ai/slide-15.webp';
import OperatingModelSlide from '../../assets/projects/sale-ai/slide-17.webp';
import KpiSlide from '../../assets/projects/sale-ai/slide-20.webp';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const isVi = locale === 'vi';

const copy = isVi
	? {
			title: 'ADG Sale AI - AI Agent cho hệ thống phân phối quy mô lớn',
			description:
				'Project detail về ADG Sale AI: lớp AI Agent cho hệ thống phân phối 2.000 đại lý, giúp tư vấn, báo giá, tạo đơn hàng và tra cứu kinh doanh dưới 60 giây.',
			back: '← Về trang chủ',
			badge: 'Sale AI case study',
			role: 'AI Agent / Product Architect',
			heroTitle: 'AI Agent bán hàng cho mạng lưới 2.000 đại lý.',
			heroLead:
				'ADG Sale AI tối ưu lớp giao tiếp cuối giữa đại lý, sales và hệ thống lõi SAP/CRM: tư vấn từ hình ảnh, so sánh sản phẩm, tạo báo giá, tạo đơn hàng và tra cứu dữ liệu kinh doanh 24/7.',
			cta: 'Xem mô hình Sale AI',
			statsTitle: 'Impact từ case study',
			stats: [
				{ value: '2.000', label: 'đại lý C1/C2 trong hệ thống phân phối' },
				{ value: '<60s', label: 'mục tiêu tạo báo giá và đơn hàng' },
				{ value: '5-15m', label: 'thời gian phản hồi cũ tại điểm bán' },
				{ value: '70–80%', label: 'giảm thời gian tư vấn & báo giá' },
				{ value: '10–15%', label: 'doanh thu tăng thêm minh họa' },
				{ value: '6–9m', label: 'payback period ước tính' },
			],
			modelTitle: 'Lớp AI Agent nằm giữa con người và hệ thống lõi',
			modelLead:
				'Giải pháp không thay thế SAP/CRM. Nó đóng vai trò lớp giao tiếp tự nhiên giúp đại lý và đội sales khai thác dữ liệu, tài liệu kỹ thuật, bảng giá và quy trình đặt hàng dễ hơn ngay tại điểm bán.',
			layers: [
				{ title: 'Tư vấn từ hình ảnh', text: 'Nhận ảnh/ngữ cảnh khách hàng để gợi ý dòng cửa, kích thước, vật liệu và cấu hình phù hợp.' },
				{ title: 'So sánh sản phẩm', text: 'Đối chiếu theo ngân sách, kích thước, nhu cầu, quy cách kỹ thuật và điều kiện thi công.' },
				{ title: 'Báo giá dưới 60 giây', text: 'Tạo báo giá nhanh, chuẩn dữ liệu và giảm sai sót so với thao tác thủ công nhiều bước.' },
				{ title: 'Tạo đơn hàng dưới 60 giây', text: 'Chuyển tư vấn thành đơn hàng với dữ liệu đồng bộ về hệ thống nghiệp vụ lõi.' },
				{ title: 'Business lookup 24/7', text: 'Tra cứu doanh số, đơn hàng, tài liệu kỹ thuật và chính sách theo quyền của từng đại lý.' },
				{ title: 'Human + AI governance', text: 'AI xử lý việc lặp lại, con người giám sát tư vấn, bảo mật và quyết định cuối cùng.' },
			],
			implementationTitle: 'Từ pain point bán hàng tới flow chốt đơn 120 giây',
			implementationLead:
				'Deck mô tả bài toán ngành cửa: sản phẩm đa dạng, bảng giá khó nhớ, tư vấn dễ sai, khách hàng kỳ vọng phản hồi tức thì. Sale AI gom quy trình thành flow: upload ảnh, AI gợi ý, báo giá 60 giây và lên đơn.',
			proofTitle: 'Board-level KPI & ROI',
			cases: [
				{ value: '+5%', label: 'conversion uplift', text: 'Kịch bản minh họa tăng chuyển đổi từ 20% lên 25% nhờ phản hồi nhanh và tư vấn chuẩn.' },
				{ value: '3–5x', label: 'ROI năm đầu', text: 'Ước tính tác động tài chính so với chi phí đầu tư AI Agent trong năm đầu.' },
				{ value: '10 khách', label: 'mỗi đại lý / ngày', text: 'Giả định quy mô vận hành để lượng hóa tác động cho mạng lưới 2.000 đại lý.' },
				{ value: '24/7', label: 'hỗ trợ đại lý', text: 'Tra cứu dữ liệu kinh doanh, kỹ thuật và đào tạo liên tục, cá nhân hóa theo đại lý.' },
			],
			featureTitle: 'Core capabilities',
			features: ['Image-to-quote', 'Product comparison', 'Quote <60s', 'Order <60s', 'Dealer personalization', 'SAP / CRM bridge', 'Technical documents', 'Training assistant', 'AI adoption KPI', 'Human-in-the-loop'],
			galleryTitle: 'Gallery từ Doc + Slides',
			closing: 'Sale AI là ví dụ sắc nét cho cách tôi triển khai AI trong doanh nghiệp lớn: không thay lõi ERP/CRM, mà tối ưu điểm chạm cuối nơi tốc độ, trải nghiệm và doanh thu được quyết định.',
			contact: 'Trao đổi về Sale AI / AI Agent cho sales',
			gallery: [
				{ title: 'AI Agent trong chuỗi giá trị', image: AgentConceptSlide },
				{ title: 'Case ADG Sale AI tại hội nghị đại lý', image: CaseSlide },
				{ title: 'Bức tranh hiệu quả AI toàn doanh nghiệp', image: EnterpriseImpactSlide },
				{ title: 'Nỗi đau ngành cửa', image: PainSlide },
				{ title: 'Mục tiêu chiến lược', image: StrategySlide },
				{ title: 'Báo giá 60 giây', image: QuoteSlide },
				{ title: 'Flow 120 giây chốt đơn', image: FlowSlide },
				{ title: 'Nguyên tắc Human + AI', image: OperatingModelSlide },
				{ title: 'KPI chính của dự án', image: KpiSlide },
			],
		}
	: {
			title: 'ADG Sale AI - AI Agent for large-scale distribution networks',
			description:
				'ADG Sale AI project detail: an AI Agent layer for a 2,000-dealer distribution system, enabling consultation, quoting, order creation, and business lookup in under 60 seconds.',
			back: '← Back home',
			badge: 'Sale AI case study',
			role: 'AI Agent / Product Architect',
			heroTitle: 'A sales AI Agent for a 2,000-dealer network.',
			heroLead:
				'ADG Sale AI optimizes the last-mile interface between dealers, sales teams, and SAP/CRM: image-based consultation, product comparison, quotes, orders, and 24/7 business lookup.',
			cta: 'View Sale AI model',
			statsTitle: 'Case-study impact',
			stats: [
				{ value: '2,000', label: 'C1/C2 dealers in the distribution network' },
				{ value: '<60s', label: 'target quote and order creation time' },
				{ value: '5→15m', label: 'previous point-of-sale response time' },
				{ value: '70–80%', label: 'less consultation and quoting time' },
				{ value: '10–15%', label: 'illustrative incremental revenue' },
				{ value: '6–9m', label: 'estimated payback period' },
			],
			modelTitle: 'An AI Agent layer between people and core systems',
			modelLead:
				'The solution does not replace SAP/CRM. It acts as a natural-language interface that helps dealers and sales teams use data, technical documents, pricing, and ordering workflows at the point of sale.',
			layers: [
				{ title: 'Image-based consultation', text: 'Use customer images and context to recommend door lines, dimensions, materials, and configurations.' },
				{ title: 'Product comparison', text: 'Compare options by budget, dimensions, needs, technical specifications, and installation context.' },
				{ title: 'Quotes under 60 seconds', text: 'Generate fast, data-aligned quotes while reducing errors from manual multi-step work.' },
				{ title: 'Orders under 60 seconds', text: 'Turn consultation into orders with synchronized data back to core business systems.' },
				{ title: 'Business lookup 24/7', text: 'Retrieve sales, orders, technical documents, and policies based on each dealer’s permissions.' },
				{ title: 'Human + AI governance', text: 'AI handles repetitive work while humans supervise recommendations, security, and final decisions.' },
			],
			implementationTitle: 'From sales pain points to a 120-second closing flow',
			implementationLead:
				'The deck frames the door industry pain points: diverse products, hard-to-remember price rules, error-prone consultation, and customers expecting instant responses. Sale AI compresses the workflow into: upload image, AI suggestion, 60-second quote, and order creation.',
			proofTitle: 'Board-level KPI & ROI',
			cases: [
				{ value: '+5%', label: 'conversion uplift', text: 'Illustrative scenario: conversion improves from 20% to 25% through faster response and standardized consultation.' },
				{ value: '3–5x', label: 'first-year ROI', text: 'Estimated financial impact versus AI Agent investment cost in year one.' },
				{ value: '10 clients', label: 'per dealer / day', text: 'Operating assumption used to quantify impact across a 2,000-dealer network.' },
				{ value: '24/7', label: 'dealer support', text: 'Continuous business, technical, and training lookup personalized by dealer.' },
			],
			featureTitle: 'Core capabilities',
			features: ['Image-to-quote', 'Product comparison', 'Quote <60s', 'Order <60s', 'Dealer personalization', 'SAP / CRM bridge', 'Technical documents', 'Training assistant', 'AI adoption KPI', 'Human-in-the-loop'],
			galleryTitle: 'Doc + deck gallery',
			closing: 'Sale AI shows how I deploy AI in large enterprises: not by replacing ERP/CRM, but by optimizing the final customer-facing layer where speed, experience, and revenue are decided.',
			contact: 'Discuss Sale AI / sales AI Agents',
			gallery: [
				{ title: 'AI Agents in the value chain', image: AgentConceptSlide },
				{ title: 'ADG Sale AI at the dealer conference', image: CaseSlide },
				{ title: 'Enterprise-wide AI impact map', image: EnterpriseImpactSlide },
				{ title: 'Door-industry pain points', image: PainSlide },
				{ title: 'Strategic objective', image: StrategySlide },
				{ title: '60-second quote', image: QuoteSlide },
				{ title: '120-second closing flow', image: FlowSlide },
				{ title: 'Human + AI principles', image: OperatingModelSlide },
				{ title: 'Project KPIs', image: KpiSlide },
			],
		};
---

<BaseHead title={`${copy.title} | ${SITE_TITLE}`} description={copy.description} />

<body class="sale-ai-project-shell">
	<Header locale={locale} />
	<main>
		<div class="page-wrap">
			<section class="hero-section">
				<div class="hero-copy">
					<a class="back-link" href={localizePath('/', locale)}>{copy.back}</a>
					<div class="eyebrow"><span>{copy.badge}</span><span>{copy.role}</span></div>
					<h1>{copy.heroTitle}</h1>
					<p>{copy.heroLead}</p>
					<a class="primary-link" href="#model">{copy.cta}</a>
				</div>
				<div class="hero-visual">
					<Image src={EventFeature} alt="ADG Sale AI dealer conference product demo" widths={[640, 900, 1200]} sizes="(max-width: 900px) 92vw, 45vw" loading="eager" />
				</div>
			</section>

			<section class="stats-section" aria-labelledby="stats-title">
				<div>
					<p class="section-kicker">Numbers</p>
					<h2 id="stats-title">{copy.statsTitle}</h2>
				</div>
				<div class="stats-grid">
					{copy.stats.map((stat) => (
						<article>
							<strong>{stat.value}</strong>
							<span>{stat.label}</span>
						</article>
					))}
				</div>
			</section>

			<section class="model-section" id="model">
				<div class="section-heading">
					<p class="section-kicker">AI Agent layer</p>
					<h2>{copy.modelTitle}</h2>
					<p>{copy.modelLead}</p>
				</div>
				<div class="layer-grid">
					{copy.layers.map((layer, index) => (
						<article>
							<span>{String(index + 1).padStart(2, '0')}</span>
							<h3>{layer.title}</h3>
							<p>{layer.text}</p>
						</article>
					))}
				</div>
			</section>

			<section class="feature-section">
				<div class="feature-copy">
					<p class="section-kicker">Sales workflow</p>
					<h2>{copy.implementationTitle}</h2>
					<p>{copy.implementationLead}</p>
					<div class="feature-cloud">
						{copy.features.map((feature) => <span>{feature}</span>)}
					</div>
				</div>
				<Image src={QuoteFeature} alt="ADG Sale AI 60-second quote product interface" widths={[640, 900, 1150]} sizes="(max-width: 900px) 92vw, 42vw" />
			</section>

			<section class="proof-section">
				<div class="section-heading compact">
					<p class="section-kicker">Proof</p>
					<h2>{copy.proofTitle}</h2>
				</div>
				<div class="proof-grid">
					{copy.cases.map((item) => (
						<article>
							<strong>{item.value}</strong>
							<span>{item.label}</span>
							<p>{item.text}</p>
						</article>
					))}
				</div>
			</section>

			<section class="gallery-section">
				<div class="section-heading compact">
					<p class="section-kicker">Source material</p>
					<h2>{copy.galleryTitle}</h2>
				</div>
				<div class="gallery-grid">
					{copy.gallery.map((item) => (
						<figure>
							<Image src={item.image} alt={item.title} widths={[480, 720, 1100]} sizes="(max-width: 900px) 92vw, 31vw" />
							<figcaption>{item.title}</figcaption>
						</figure>
					))}
				</div>
			</section>

			<section class="closing-section">
				<p>{copy.closing}</p>
				<a class="primary-link" href="mailto:hello@thanhtung.com">{copy.contact}</a>
			</section>
		</div>
	</main>
	<Footer />
</body>

<style>
	:global(body.sale-ai-project-shell) {
		margin: 0;
		background:
			radial-gradient(circle at top left, rgb(255 128 0 / 0.14), transparent 34rem),
			linear-gradient(180deg, #fffaf5 0%, #fff 36%, #f6f2ec 100%);
		color: #17120d;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}

	:global(.sale-ai-project-shell main) {
		min-height: 100vh;
	}

	.page-wrap {
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
	}

	.hero-section {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(340px, 1.08fr);
		gap: clamp(1.25rem, 4vw, 3.8rem);
		align-items: center;
		min-height: min(690px, calc(100dvh - 88px));
		padding: clamp(1rem, 3vw, 2.6rem) 0 clamp(2rem, 5vw, 4rem);
	}

	.back-link {
		color: #8a4f17;
		font-weight: 800;
		font-size: 0.92rem;
		text-decoration: none;
	}

	.hero-copy {
		display: grid;
		gap: 1.3rem;
	}

	.eyebrow {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.eyebrow span,
	.feature-cloud span {
		border: 1px solid rgb(236 115 21 / 0.24);
		background: rgb(255 255 255 / 0.82);
		color: #8f4e10;
		font-weight: 850;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.52rem 0.78rem;
		border-radius: 999px;
	}

	h1 {
		font-size: clamp(2.65rem, 5.25vw, 5.45rem);
		letter-spacing: -0.066em;
		line-height: 0.96;
		max-width: 11.8ch;
		margin: 0;
	}

	.hero-copy p,
	.section-heading p,
	.feature-copy p,
	.closing-section p {
		font-size: clamp(1.02rem, 1.5vw, 1.22rem);
		line-height: 1.7;
		color: #5f5148;
		margin: 0;
	}

	.primary-link {
		display: inline-flex;
		width: fit-content;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: #f58220;
		color: #fff;
		font-weight: 900;
		padding: 0.92rem 1.18rem;
		text-decoration: none;
		box-shadow: 0 18px 45px rgb(245 130 32 / 0.24);
	}

	.hero-visual,
	.feature-section,
	.stats-section,
	.closing-section {
		border: 1px solid rgb(36 24 10 / 0.08);
		border-radius: 34px;
		background: rgb(255 255 255 / 0.76);
		box-shadow: 0 28px 70px rgb(48 31 9 / 0.1);
	}

	.hero-visual {
		padding: clamp(0.7rem, 1.8vw, 1.35rem);
		transform: rotate(1.1deg);
	}

	.hero-visual img,
	.feature-section img,
	.gallery-grid img {
		width: 100%;
		height: auto;
		border-radius: 24px;
		display: block;
	}

	.stats-section,
	.model-section,
	.feature-section,
	.proof-section,
	.gallery-section,
	.closing-section {
		margin: clamp(2.5rem, 8vw, 6.4rem) 0;
	}

	.stats-section,
	.feature-section,
	.closing-section {
		padding: clamp(1.4rem, 4vw, 3rem);
	}

	.stats-section {
		display: grid;
		grid-template-columns: 0.72fr 1.28fr;
		gap: clamp(1.2rem, 4vw, 3rem);
		align-items: start;
	}

	.section-kicker {
		margin: 0 0 0.75rem;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: #f58220;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 4.4rem);
		letter-spacing: -0.055em;
		line-height: 0.96;
		margin: 0;
	}

	.stats-grid,
	.layer-grid,
	.proof-grid,
	.gallery-grid {
		display: grid;
		gap: 1rem;
	}

	.stats-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.stats-grid article,
	.layer-grid article,
	.proof-grid article,
	.gallery-grid figure {
		border: 1px solid rgb(36 24 10 / 0.08);
		border-radius: 24px;
		background: rgb(255 255 255 / 0.86);
		padding: 1rem;
		margin: 0;
	}

	.stats-grid strong,
	.proof-grid strong {
		display: block;
		font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		font-size: clamp(1.62rem, 3vw, 2.95rem);
		font-variant-numeric: tabular-nums;
		line-height: 1;
		letter-spacing: -0.025em;
		white-space: nowrap;
		color: #f58220;
	}

	.stats-grid span,
	.proof-grid span {
		display: block;
		margin-top: 0.6rem;
		color: #5f5148;
		font-weight: 750;
		line-height: 1.35;
	}

	.section-heading {
		max-width: 760px;
		margin-bottom: clamp(1.3rem, 4vw, 2.4rem);
	}

	.section-heading.compact {
		max-width: 620px;
	}

	.layer-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.layer-grid span {
		color: #f58220;
		font-weight: 950;
		font-size: 0.84rem;
	}

	.layer-grid h3 {
		font-size: 1.15rem;
		margin: 0.8rem 0 0.55rem;
	}

	.layer-grid p,
	.proof-grid p,
	.gallery-grid figcaption {
		color: #685a50;
		line-height: 1.55;
		margin: 0;
	}

	.feature-section {
		display: grid;
		grid-template-columns: minmax(0, 0.88fr) minmax(320px, 1.12fr);
		gap: clamp(1rem, 4vw, 3rem);
		align-items: center;
	}

	.feature-copy {
		display: grid;
		gap: 1.2rem;
	}

	.feature-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.proof-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.gallery-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.gallery-grid figure {
		padding: 0.65rem;
	}

	.gallery-grid figcaption {
		padding: 0.8rem 0.35rem 0.2rem;
		font-weight: 800;
	}

	.closing-section {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}

	.closing-section p {
		max-width: 760px;
		font-weight: 760;
		color: #24180f;
	}

	@media (max-width: 980px) {
		.hero-section,
		.stats-section,
		.feature-section {
			grid-template-columns: 1fr;
		}

		.hero-section {
			min-height: auto;
		}

		.hero-visual {
			transform: none;
		}

		.layer-grid,
		.proof-grid,
		.gallery-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.page-wrap {
			width: min(100% - 1rem, 1180px);
		}

		h1 {
			font-size: clamp(2.2rem, 10.5vw, 3.25rem);
			max-width: 12.2ch;
		}

		.stats-grid,
		.layer-grid,
		.proof-grid,
