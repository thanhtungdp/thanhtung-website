---
import AboutHeroImage from '../../assets/blog-placeholder-about.jpg';
import Layout from '../../layouts/BlogPost.astro';
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const isVi = locale === 'vi';
---

<Layout
	title={t.about.title}
	description={t.about.description}
	pubDate={new Date('August 08 2021')}
	heroImage={AboutHeroImage}
	locale={locale}
>
	{
		isVi ? (
			<>
				<p>
					Tôi quan tâm đến cách doanh nghiệp biến chiến lược thành nhịp vận hành hằng ngày. Website này là nơi lưu lại các quan sát, case study và framework có thể dùng ngay trong đội nhóm.
				</p>
				<h2>Tôi thường viết về gì?</h2>
				<ul>
					<li>Thiết kế mục tiêu, OKRs và cơ chế đo lường rõ ràng.</li>
					<li>Xây dựng nhịp họp, dashboard và trách nhiệm theo vai trò.</li>
					<li>Ứng dụng công nghệ để giảm ma sát trong vận hành.</li>
					<li>Văn hoá minh bạch giúp đội ngũ phối hợp tốt hơn.</li>
				</ul>
				<h2>Cách đọc</h2>
				<p>
					Mỗi bài được viết theo hướng thực tế: bối cảnh, vấn đề, cách triển khai và bài học. Nếu một ý tưởng không giúp đội nhóm hành động rõ hơn, tôi sẽ cắt bớt.
				</p>
			</>
		) : (
			<>
				<p>
					I care about how companies turn strategy into daily operating rhythm. This site collects practical observations, case studies, and frameworks that teams can apply quickly.
				</p>
				<h2>What I write about</h2>
				<ul>
					<li>Clear goals, OKRs, and measurement systems.</li>
					<li>Meeting rhythms, dashboards, and role ownership.</li>
					<li>Technology that removes friction from operations.</li>
					<li>Transparent culture that helps teams coordinate better.</li>
				</ul>
				<h2>How to read</h2>
				<p>
					Each article focuses on context, the problem, implementation, and lessons learned. If an idea does not help a team act with more clarity, it gets cut.
				</p>
			</>
		)
	}
</Layout>
