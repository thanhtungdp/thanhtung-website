---
interface Props {
	class?: string;
}

const { class: className = '' } = Astro.props;
---

<span
	class={`inline-flex items-center justify-center rounded-full border border-[rgb(var(--border))] bg-white/75 px-3 py-1.5 text-[0.86rem] font-extrabold text-[rgb(var(--primary))] shadow-sm backdrop-blur ${className}`}
>
	<slot />
</span>
