---
import { Image } from 'astro:assets';
import AiAgentsImage from '../../assets/projects/ai-agents.png';
import AiProgramImage from '../../assets/projects/ai-product-program.png';
import ILotusLandImage from '../../assets/projects/ilotusland.png';
import TeachingImage from '../../assets/projects/teaching-scale.png';
import BaseHead from '../BaseHead.astro';
import Footer from '../Footer.astro';
import FormattedDate from '../FormattedDate.astro';
import Header from '../Header.astro';
import { MotionProjectGrid, MotionStatsGrid, TiltProfileCard, X10Mark } from '../motion/HomeMotion';
import { SITE_TITLE } from '../../consts';
import { getTranslations, localizePath, type Locale } from '../../i18n';
import { getBlogPath, getBlogPosts } from '../../lib/blog';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const isVi = locale === 'vi';
const latestPosts = (await getBlogPosts(locale)).slice(0, 3);

const projects = isVi
	? [
			{
				title: 'iLotusLand Industrial IoT',
				desc: 'Nền tảng quan trắc công nghiệp với hơn 1.000 trạm, phục vụ FDI, nhà máy và cơ quan nhà nước.',
				image: ILotusLandImage,
				meta: 'IoT Platform',
				role: 'Founder / Architect',
				impact: '1,000+ trạm',
				domain: 'Industrial IoT',
				cta: 'Xem case study',
			},
			{
				title: 'Simplamo Strategy AI',
				desc: 'AI tạo OKRs, KPIs và mục tiêu quý từ ngữ cảnh quản trị thật, đang dùng trong nền tảng Simplamo.',
				image: AiAgentsImage,
				meta: 'AI Agent',
				role: 'Product Architect',
				impact: '100+ tổ chức',
				domain: 'OKR / KPI / 4DX',
				cta: 'Đọc câu chuyện',
			},
			{
				title: 'Pascal tới 1 triệu học sinh',
				desc: 'Biến một chủ đề khô thành trải nghiệm học cuốn hút, đạt hơn 1 triệu lượt xem và tiếp cận học sinh quy mô lớn.',
				image: TeachingImage,
				meta: 'Education',
				role: 'Educator',
				impact: '1M+ lượt xem',
				domain: 'Learning at scale',
				cta: 'Xem hành trình',
			},
			{
				title: 'AI Product Training Program',
				desc: 'Chương trình học theo nhịp mỗi ngày có sản phẩm chạy thật: web, mobile, backend và AI.',
				image: AiProgramImage,
				meta: 'Training System',
				role: 'Program Designer',
				impact: 'Build-first',
				domain: 'AI / Web / Mobile',
				cta: 'Khám phá chương trình',
			},
		]
	: [
			{
				title: 'iLotusLand Industrial IoT',
				desc: 'An industrial monitoring platform with 1,000+ stations serving FDI factories and public agencies.',
				image: ILotusLandImage,
				meta: 'IoT Platform',
				role: 'Founder / Architect',
				impact: '1,000+ stations',
				domain: 'Industrial IoT',
				cta: 'View case study',
			},
			{
				title: 'Simplamo Strategy AI',
				desc: 'AI that generates OKRs, KPIs, and quarterly goals from real business context inside Simplamo.',
				image: AiAgentsImage,
				meta: 'AI Agent',
				role: 'Product Architect',
				impact: '100+ organizations',
				domain: 'OKR / KPI / 4DX',
				cta: 'Read story',
			},
			{
				title: 'Pascal to 1M learners',
				desc: 'Turned a dry technical subject into engaging lessons that reached more than one million views.',
				image: TeachingImage,
				meta: 'Education',
				role: 'Educator',
				impact: '1M+ views',
				domain: 'Learning at scale',
				cta: 'View journey',
			},
			{
				title: 'AI Product Training Program',
				desc: 'A build-first learning arc where every day ends with a product that runs.',
				image: AiProgramImage,
				meta: 'Training System',
				role: 'Program Designer',
				impact: 'Build-first',
				domain: 'AI / Web / Mobile',
				cta: 'Explore program',
			},
		];

const projectCards = projects.map((project) => ({ ...project, imageSrc: project.image.src }));

const services = isVi
	? [
			'Tư vấn chiến lược, OKRs, BSC, KPI và 4DX cho doanh nghiệp đang tăng trưởng.',
			'Thiết kế hệ thống AI agent từ bài toán kinh doanh tới sản phẩm chạy thật.',
			'Đào tạo AI product, web, mobile, backend và tư duy sản phẩm cho đội ngũ.',
			'Cố vấn vận hành để biến mục tiêu thành nhịp họp, dashboard và trách nhiệm rõ ràng.',
		]
	: [
			'Advise on strategy, OKRs, BSC, KPI, and 4DX for growing companies.',
			'Design AI agent systems from business problem to working product.',
			'Train teams in AI products, web, mobile, backend, and product thinking.',
			'Help leaders turn goals into meeting rhythm, dashboards, and clear ownership.',
		];

const stats = [
	{ value: '1M+', label: isVi ? 'học sinh đã tiếp cận' : 'learners reached' },
	{ value: '1,000+', label: isVi ? 'trạm quan trắc' : 'monitoring stations' },
	{ value: '600+', label: isVi ? 'nhà máy FDI phục vụ' : 'FDI factories served' },
	{ value: '100+', label: isVi ? 'tổ chức dùng Simplamo' : 'organizations using Simplamo' },
];

const proofStats = isVi
	? [
			{ value: '1M+', label: 'học sinh tiếp cận' },
			{ value: '1,000+', label: 'trạm IoT' },
			{ value: '100+', label: 'tổ chức dùng Simplamo' },
			{ value: 'AI / SaaS', label: 'sản phẩm thật' },
		]
	: [
			{ value: '1M+', label: 'learners reached' },
			{ value: '1,000+', label: 'IoT stations' },
			{ value: '100+', label: 'Simplamo organizations' },
			{ value: 'AI / SaaS', label: 'real products' },
		];

const profileCard = {
	name: 'Phan Thanh Tung',
	title: isVi ? 'Tech Visionary. Serial Founder. Full-Stack Architect.' : 'Tech Visionary. Serial Founder. Full-Stack Architect.',
	location: 'Ho Chi Minh City',
	email: 'thanhtung@simplamo.com',
	focus: isVi ? 'Đang xây Simplamo, AI agents và chương trình đào tạo sản phẩm AI.' : 'Building Simplamo, AI agents, and practical AI product training.',
	status: isVi ? 'Đang xây Simplamo' : 'Building Simplamo',
};
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={SITE_TITLE} description={t.siteDescription} locale={locale} />
	</head>
	<body>
		<Header />
		<main class="home-shell">
			<section class="hero section-block">
				<div class="hero-copy motion-hero-copy">
					<p class="kicker">{isVi ? 'Xây AI · Giáo dục · Vận hành' : 'AI builder · educator · operator'}</p>
					<h1>
						<span>Simple</span>
						<span>Technology</span>
						<span>enables <X10Mark client:load /></span>
						<span>Operations</span>
					</h1>
					<p class="hero-lead">
						{
							isVi
								? 'Tôi xây sản phẩm AI thật, thắp lửa lớp học và giúp người học trở thành maker có sản phẩm với người dùng thật.'
								: 'I build real AI products, ignite classrooms, and turn learners into makers with products used by real people.'
						}
					</p>
					<div class="hero-actions">
						<a class="button-primary" href={localizePath('/blog', locale)}>{isVi ? 'Đọc bài viết' : 'Read writing'}</a>
						<a class="button-secondary" href="mailto:thanhtung@simplamo.com">{isVi ? 'Liên hệ' : 'Contact'}</a>
					</div>
					<div class="proof-strip surface-card" aria-label={isVi ? 'Bằng chứng nhanh' : 'Quick proof'}>
						{proofStats.map((item) => <div><strong>{item.value}</strong><span>{item.label}</span></div>)}
					</div>
				</div>
				<TiltProfileCard {...profileCard} client:load />
			</section>

			<section class="section-block featured-projects">
				<div class="section-title">
					<p>{isVi ? 'Dự án nổi bật' : 'Featured projects'}</p>
					<h2>{isVi ? '4 dự án nổi bật' : '4 featured projects'}</h2>
				</div>
				<MotionProjectGrid projects={projectCards} client:visible />
			</section>

			<section class="section-block doing-section">
				<div class="section-title narrow">
					<p>{isVi ? 'Tôi làm gì' : 'What I do'}</p>
					<h2>{isVi ? 'Tôi giúp đội ngũ học nhanh hơn và vận hành sắc hơn' : 'I help teams learn faster and operate sharper'}</h2>
				</div>
				<div class="service-list">
					{services.map((item, index) => <div class="service-item"><span>{`0${index + 1}`}</span><p>{item}</p></div>)}
				</div>
			</section>

			<section class="section-block writing-section">
				<div class="section-title writing-title">
					<div>
						<p>{isVi ? 'Bài viết mới' : 'Latest writing'}</p>
						<h2>{isVi ? 'Góc blog & chia sẻ' : 'Blog & field notes'}</h2>
					</div>
					<a class="button-secondary compact" href={localizePath('/blog', locale)}>{isVi ? 'Xem tất cả' : 'View all'}</a>
				</div>
				<div class="blog-grid">
					{
						latestPosts.map((post) => (
							<article class:list={['blog-card', 'surface-card', { 'has-media': Boolean(post.data.heroImage) }]}>
								<a href={getBlogPath(post, locale)}>
									{post.data.heroImage && (
										<Image src={post.data.heroImage} width={520} height={300} alt="" loading="lazy" />
									)}
									<div>
										<span><FormattedDate date={post.data.pubDate} locale={locale} /></span>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
									</div>
								</a>
							</article>
						))
					}
				</div>
			</section>

			<section class="section-block stats-section surface-card">
				<div class="section-title narrow">
					<p>{isVi ? 'Con số thực tế' : 'Statistics'}</p>
					<h2>{isVi ? 'Những con số đã chạy ngoài đời thật' : 'Numbers from real systems'}</h2>
				</div>
				<MotionStatsGrid stats={stats} client:visible />
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.home-shell {
		padding-top: 3.5rem;
	}

	.section-block {
		position: relative;
		padding: clamp(2.75rem, 7vw, 5.5rem) 0;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
		gap: clamp(1.5rem, 4vw, 4rem);
		align-items: center;
		min-height: min(620px, calc(100dvh - 8rem));
		padding-top: 1rem;
	}

	.kicker,
	.section-title p {
		display: inline-flex;
		margin-bottom: 1rem;
		padding: 0.42rem 0.72rem;
		border: 1px solid rgb(var(--border));
		border-radius: 999px;
		background: rgb(255 255 255 / 0.82);
		color: rgb(var(--primary));
		font-size: 0.82rem;
		font-weight: 850;
		letter-spacing: 0.01em;
	}

	.hero h1 {
		max-width: 11ch;
		font-size: clamp(3.1rem, 7.6vw, 6.6rem);
		line-height: 0.94;
		letter-spacing: -0.07em;
	}

	.hero h1 > span {
		display: block;
	}

	.motion-hero-copy > .kicker,
	.motion-hero-copy h1 > span,
	.motion-hero-copy .hero-lead,
	.motion-hero-copy .hero-actions,
	.motion-hero-copy .proof-strip {
		animation: hero-rise 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
	}

	.motion-hero-copy h1 > span:nth-child(1) { animation-delay: 80ms; }
	.motion-hero-copy h1 > span:nth-child(2) { animation-delay: 150ms; }
	.motion-hero-copy h1 > span:nth-child(3) { animation-delay: 220ms; }
	.motion-hero-copy h1 > span:nth-child(4) { animation-delay: 290ms; }
	.motion-hero-copy .hero-lead { animation-delay: 360ms; }
	.motion-hero-copy .hero-actions { animation-delay: 430ms; }
	.motion-hero-copy .proof-strip { animation-delay: 500ms; }

	@keyframes hero-rise {
		from { opacity: 0; transform: translateY(24px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.x10-wrap {
		display: inline-flex;
		position: relative;
		isolation: isolate;
	}

	.x10-mark {
		display: inline-block;
		min-width: 1.55em;
		color: rgb(var(--primary));
	}

	.x10-wrap::after {
		content: "";
		position: absolute;
		left: 0.04em;
		right: 0.08em;
		bottom: 0.02em;
		z-index: -1;
		height: 0.12em;
		border-radius: 999px;
		background: rgb(var(--primary) / 0.22);
		transform-origin: left;
		animation: x10-sweep 820ms cubic-bezier(0.16, 1, 0.3, 1) 700ms both;
	}

	@keyframes x10-sweep {
		from { transform: scaleX(0); }
		to { transform: scaleX(1); }
	}

	.hero-lead {
		max-width: 58ch;
		margin-top: 1.25rem;
		color: rgb(var(--muted-foreground));
		font-size: clamp(1.08rem, 2vw, 1.28rem);
		line-height: 1.62;
	}

	.hero-actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-top: 1.8rem;
	}

	.proof-strip {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.5rem;
		margin-top: 1.35rem;
		padding: 0.7rem;
		background: rgb(255 255 255 / 0.78);
	}

	.proof-strip div {
		padding: 0.55rem 0.6rem;
		border-radius: 0.9rem;
		background: rgb(255 247 237 / 0.72);
	}

	.proof-strip strong,
	.proof-strip span {
		display: block;
	}

	.proof-strip strong {
		color: rgb(var(--foreground));
		font-size: clamp(1rem, 1.9vw, 1.32rem);
		line-height: 1;
		letter-spacing: -0.04em;
	}

	.proof-strip span {
		margin-top: 0.32rem;
		color: rgb(var(--muted-foreground));
		font-size: 0.76rem;
		font-weight: 800;
		line-height: 1.22;
	}

	.profile-card {
		position: relative;
		overflow: hidden;
		padding: clamp(1.25rem, 3vw, 2rem);
		background: rgb(10 10 10);
		color: white;
		border-color: rgb(10 10 10);
		transform-style: preserve-3d;
	}

	.profile-glow {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.profile-topline,
	.profile-card h2,
	.profile-focus,
	.profile-meta {
		position: relative;
		z-index: 1;
	}

	.profile-topline {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 1.6rem;
	}

	.profile-topline p {
		margin: 0;
		color: rgb(251 146 60);
		font-size: 0.95rem;
		font-weight: 850;
	}

	.profile-topline span {
		padding: 0.34rem 0.58rem;
		border: 1px solid rgb(255 255 255 / 0.14);
		border-radius: 999px;
		background: rgb(255 255 255 / 0.06);
		color: rgb(245 245 245);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
		white-space: nowrap;
	}

	.profile-card h2 {
		max-width: 12ch;
		color: white;
		font-size: clamp(2rem, 5vw, 4.25rem);
		line-height: 0.98;
	}

	.profile-focus {
		max-width: 31ch;
		margin: 1.1rem 0 0;
		color: rgb(229 229 229);
		font-size: 0.98rem;
		font-weight: 700;
		line-height: 1.45;
	}

	.profile-meta {
		display: flex;
		gap: 0.55rem;
		align-items: center;
		flex-wrap: wrap;
		margin-top: 2rem;
		color: rgb(212 212 212);
		font-size: 0.95rem;
	}

	.section-title {
		margin-bottom: 1.5rem;
	}

	.section-title.narrow {
		max-width: 760px;
	}

	.section-title h2 {
		max-width: 12ch;
		font-size: clamp(2.25rem, 6vw, 5.2rem);
		line-height: 0.96;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.project-card {
		overflow: hidden;
		background: rgb(255 255 255 / 0.88);
		transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
	}

	.project-card:hover {
		transform: translateY(-5px);
		border-color: rgb(var(--primary) / 0.42);
		box-shadow: 0 18px 58px rgb(15 23 42 / 0.12);
	}

	.project-card:hover .thumb img {
		transform: scale(1.035);
	}

	.thumb {
		padding: 0.45rem;
		background: rgb(10 10 10);
		overflow: hidden;
	}

	.thumb img {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: 0.8rem;
		transition: transform 420ms cubic-bezier(0.16, 1, 0.3, 1);
	}

	.project-body {
		display: grid;
		gap: 0.95rem;
		padding: clamp(1rem, 2.4vw, 1.5rem);
	}

	.project-kicker-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.project-kicker-row span {
		display: inline-flex;
		align-items: center;
		min-height: 1.7rem;
		padding: 0.28rem 0.58rem;
		border: 1px solid rgb(var(--border));
		border-radius: 999px;
		background: rgb(255 247 237 / 0.72);
		color: rgb(var(--primary));
		font-size: 0.72rem;
		font-weight: 850;
		line-height: 1;
	}

	.project-body h3 {
		margin: 0;
		font-size: clamp(1.25rem, 3vw, 2rem);
	}

	.project-body p {
		margin: 0;
		color: rgb(var(--muted-foreground));
		font-size: 0.98rem;
		line-height: 1.56;
	}

	.project-proof {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
		gap: 0.55rem;
		padding: 0.75rem;
		border-radius: 0.9rem;
		background: rgb(245 245 245 / 0.78);
	}

	.project-proof strong,
	.project-proof span {
		display: block;
		line-height: 1.2;
	}

	.project-proof strong {
		color: rgb(var(--foreground));
		font-size: 1rem;
		letter-spacing: -0.035em;
	}

	.project-proof span {
		color: rgb(var(--muted-foreground));
		font-size: 0.82rem;
		font-weight: 800;
	}

	.project-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.42rem;
		width: fit-content;
		color: rgb(var(--primary));
		font-size: 0.9rem;
		font-weight: 900;
	}

	.project-cta span {
		transition: transform 180ms ease;
	}

	.project-card:hover .project-cta span {
		transform: translateX(3px);
	}

	.doing-section {
		display: grid;
		grid-template-columns: 0.82fr 1.18fr;
		gap: clamp(1.5rem, 5vw, 5rem);
		align-items: start;
	}

	.service-list {
		display: grid;
		gap: 0.75rem;
	}

	.service-item {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1rem;
		align-items: start;
		padding: 1.1rem;
		border: 1px solid rgb(var(--border));
		border-radius: var(--radius);
		background: rgb(255 255 255 / 0.82);
	}

	.service-item span {
		color: rgb(var(--primary));
		font-size: 0.86rem;
		font-weight: 900;
	}

	.service-item p {
		margin: 0;
		color: rgb(var(--foreground));
		font-size: clamp(1rem, 2vw, 1.18rem);
		font-weight: 700;
		line-height: 1.45;
	}

	.writing-title {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
	}

	.writing-title .compact {
		padding-inline: 1rem;
		white-space: nowrap;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.blog-card {
		overflow: hidden;
		background: rgb(255 255 255 / 0.88);
		transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
	}

	.blog-card:hover {
		transform: translateY(-3px);
		border-color: rgb(var(--primary) / 0.42);
	}

	.blog-card a {
		display: flex;
		min-height: 100%;
		color: inherit;
		text-decoration: none;
		flex-direction: column;
	}

	.blog-card img {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: 0;
	}

	.blog-card div {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 1.15rem;
	}

	.blog-card span {
		color: rgb(var(--primary));
		font-size: 0.78rem;
		font-weight: 850;
	}

	.blog-card h3 {
		margin-top: 0.5rem;
		font-size: clamp(1.05rem, 2vw, 1.35rem);
		line-height: 1.12;
		letter-spacing: -0.035em;
	}

	.blog-card p {
