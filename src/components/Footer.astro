---
import { getLocaleFromUrl, getTranslations, localizePath } from '../i18n';
import { SITE_TITLE } from '../consts';

const today = new Date();
const locale = getLocaleFromUrl(Astro.url);
const t = getTranslations(locale);
---

<footer class="site-footer">
	<div class="footer-inner">
		<div>
			<a class="footer-brand" href={localizePath('/', locale)}>{SITE_TITLE}</a>
			<p>{t.footer}</p>
		</div>
		<nav class="footer-links" aria-label="Footer navigation">
			<a href={localizePath('/', locale)}>{t.nav.home}</a>
			<a href={localizePath('/blog', locale)}>{t.nav.blog}</a>
			<a href={localizePath('/about', locale)}>{t.nav.about}</a>
		</nav>
		<p class="copyright">© {today.getFullYear()} Thanh Tung</p>
	</div>
</footer>

<style>
	.site-footer {
		padding: 3rem 1rem 4rem;
		border-top: 1px solid rgb(var(--border) / 0.78);
		background: rgb(255 255 255 / 0.52);
		color: rgb(var(--muted-foreground));
	}

	.footer-inner {
		width: min(var(--container), 100%);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 1.25rem 2rem;
		align-items: start;
	}

	.footer-brand {
		display: inline-block;
		margin-bottom: 0.45rem;
		color: rgb(var(--foreground));
		font-weight: 800;
		letter-spacing: -0.04em;
		text-decoration: none;
	}

	.footer-brand:hover,
	.footer-links a:hover {
		color: rgb(var(--primary));
	}

	.footer-inner p {
		margin: 0;
		font-size: 0.95rem;
	}

	.footer-links {
		display: flex;
		gap: 0.35rem;
		align-items: center;
		justify-content: flex-end;
		flex-wrap: wrap;
	}

	.footer-links a {
		padding: 0.45rem 0.7rem;
		border-radius: 999px;
		color: rgb(var(--muted-foreground));
		font-size: 0.92rem;
		font-weight: 700;
		text-decoration: none;
	}

	.footer-links a:hover {
		background: rgb(var(--muted));
	}

	.copyright {
		grid-column: 1 / -1;
		padding-top: 1rem;
		border-top: 1px solid rgb(var(--border) / 0.72);
	}

	@media (max-width: 760px) {
		.footer-inner {
			grid-template-columns: 1fr;
		}

		.footer-links {
			justify-content: flex-start;
		}
	}
</style>
