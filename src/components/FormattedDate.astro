---
import { defaultLocale, type Locale } from '../i18n';

interface Props {
	date: Date;
	locale?: Locale;
}

const { date, locale = defaultLocale } = Astro.props;
const dateLocale = locale === 'vi' ? 'vi-VN' : 'en-US';
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(dateLocale, {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		})
	}
</time>
