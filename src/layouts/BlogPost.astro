---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { defaultLocale, getTranslations, type Locale } from '../i18n';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, locale = defaultLocale } = Astro.props as Props & {
	locale?: Locale;
};
const t = getTranslations(locale);
---

<html lang={locale}>
	<head>
		<BaseHead title={title} description={description} image={heroImage} locale={locale} />
	</head>

	<body>
		<Header />
		<main class="article-shell">
			<article>
				<header class="article-header">
					<div class="article-meta">
						<span><FormattedDate date={pubDate} locale={locale} /></span>
						{
							updatedDate && (
								<span>
									{t.blog.updatedPrefix}&nbsp;<FormattedDate date={updatedDate} locale={locale} />
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					<p>{description}</p>
				</header>

				{heroImage && (
					<div class="hero-image surface-card">
						<Image width={1280} height={720} src={heroImage} alt="" loading="eager" />
					</div>
				)}

				<div class="article-body">
					<div class="prose">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.article-shell {
		width: min(1120px, calc(100% - 2rem));
		padding-top: 4rem;
	}

	.article-header {
		max-width: 900px;
		margin: 0 auto 2rem;
		text-align: center;
	}

	.article-meta {
		display: inline-flex;
		gap: 0.55rem;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 1rem;
		color: rgb(var(--primary));
		font-size: 0.86rem;
		font-weight: 800;
	}

	.article-meta span {
		display: inline-flex;
		padding: 0.42rem 0.7rem;
		border: 1px solid rgb(var(--border));
		border-radius: 999px;
		background: rgb(255 255 255 / 0.76);
	}

	.article-header h1 {
		font-size: clamp(2.35rem, 7vw, 5.1rem);
		letter-spacing: -0.055em;
		line-height: 1.04;
	}

	.article-header p {
		max-width: 68ch;
		margin: 1rem auto 0;
		color: rgb(var(--muted-foreground));
		font-size: clamp(1.06rem, 2vw, 1.24rem);
		line-height: 1.62;
	}

	.hero-image {
		overflow: hidden;
		margin: 0 auto 3rem;
		padding: 0.45rem;
	}

	.hero-image img {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: calc(var(--radius) + 0.05rem);
	}

	.article-body {
		max-width: 820px;
		margin: 0 auto;
		padding: clamp(1rem, 4vw, 2.2rem);
		border: 1px solid rgb(var(--border) / 0.66);
		border-radius: calc(var(--radius) + 0.5rem);
		background: rgb(255 255 255 / 0.64);
		box-shadow: var(--shadow-soft);
	}

	@media (max-width: 760px) {
		.article-shell {
			width: min(100% - 1rem, 1120px);
			padding-top: 2.5rem;
		}

		.article-header {
			text-align: left;
		}

		.article-header h1 {
			font-size: clamp(2rem, 10vw, 3.2rem);
			line-height: 1.08;
			letter-spacing: -0.045em;
		}

		.article-meta {
			justify-content: flex-start;
		}

		.hero-image {
			margin-bottom: 1.25rem;
			padding: 0.3rem;
		}

		.article-body {
			padding: 1rem;
			border-radius: var(--radius);
		}
	}
</style>
